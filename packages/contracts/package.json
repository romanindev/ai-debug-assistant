{
  "name": "@ai-debug-assistant/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist-cjs/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.cjs"
    },
    "./debug": {
      "types": "./dist/debug/index.d.ts",
      "import": "./dist/debug/index.js",
      "require": "./dist-cjs/debug/index.cjs"
    },
    "./debug/constants": {
      "types": "./dist/debug/debug.constants.d.ts",
      "import": "./dist/debug/debug.constants.js",
      "require": "./dist-cjs/debug/debug.constants.cjs"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/rename-cjs-output.cjs"
  },
  "dependencies": {
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "typescript": "~6.0.2"
  }
}
